# Environment
NODE_ENV=development

# Server
PORT=3001
HOST=localhost

# Database
DB_PATH=./data/rack_calculator.db

# JWT
JWT_SECRET=your_super_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
