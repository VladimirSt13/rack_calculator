{
  "name": "rack-calculator",
  "version": "1.0.0",
  "description": "Калькулятор стелажів та підбору акумуляторів",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "format": "prettier --write \"js/**/*.{js,json}\" \"styles/**/*.css\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"js/**/*.{js,json}\" \"styles/**/*.css\"",
    "validate": "npm run lint && npm run format:check && npm run test",
    "clean": "rm -rf dist/ node_modules/.vite/",
    "analyze": "vite-bundle-visualizer"
  },
  "keywords": [
    "rack",
    "calculator",
    "battery",
    "warehouse"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^9.3.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.0.0",
    "jsdom": "^23.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.0",
    "vite": "^5.0.0",
    "vite-bundle-visualizer": "^1.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
