{
  "name": "server-pro",
  "version": "1.0.0",
  "description": "Modular server template with authentication",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.js",
    "start": "tsx src/index.js",
    "migrate": "tsx scripts/migrate.js",
    "migrate:status": "tsx scripts/migrate.js status",
    "migrate:rollback": "tsx scripts/migrate.js rollback",
    "seed:admin": "tsx scripts/seed-admin.js",
    "lint": "eslint src --ext js",
    "format": "prettier --write \"src/**/*.{js,json}\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "clean": "rm -rf data/backups"
  },
  "keywords": [
    "express",
    "sqlite",
    "jwt",
    "authentication",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "supertest": "^6.3.4"
  }
}
